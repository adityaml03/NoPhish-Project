{
  "manifest_version": 3,
  "name": "NoPhish",
  "version": "1.2.0",
  "description": "Detects phishing using Heuristics, Random Forest AI, and DOM analysis.",
  
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://nophish-backend.onrender.com/*"
  ],
  
  "action": {
    "default_title": "NoPhish",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["indicator.css"],
      "js": [
        "heuristic.js",
        "random_forest.js",
        "dom_analyzer.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}